#!/bin/bash
#PBS -N omni-hc
#PBS -l select=1:ncpus=4:mem=24gb:ngpus=1
#PBS -l walltime=20:00:00
#PBS -j oe

set -euo pipefail

PROJECT_DIR="${PROJECT_DIR:-${PBS_O_WORKDIR:-$PWD}}"
cd "$PROJECT_DIR"

# Runs files are passed positionally, e.g.:
#   qsub scripts/hpc/gpu.pbs experiments/navier_stokes/transolver_mean_latent_engineered_data.txt
DEVICE="${DEVICE:-auto}" bash scripts/hpc/runner.sh "$@"
